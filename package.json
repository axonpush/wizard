{
  "name": "@axonpush/wizard",
  "version": "0.0.8",
  "description": "AI-powered wizard to integrate AxonPush into your AI agent project",
  "type": "module",
  "bin": {
    "axonpush-wizard": "dist/bin.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
