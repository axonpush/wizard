    "langgraph",
    "typescript",
    "python"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-toml": "^1.0.3",
    "react": "^19.2.4",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
